{
  "vocab_size": 7993,
  "max_seq_len": 128,
  "embed_dim": 192,
  "num_heads": 4,
  "num_layers": 4,
  "ff_dim": 384,
  "dropout": 0.1,
  "use_infini_attention": false,
  "segment_size": 128,
  "use_delta_rule": true,
  "use_rope": false,
  "training": {
    "batch_size": 32,
    "epochs": 5,
    "learning_rate": 0.0005,
    "weight_decay": 0.01,
    "warmup_steps": 100,
    "max_grad_norm": 1.0,
    "min_lr_ratio": 0.05,
    "log_every_n_steps": 100,
    "save_every_n_steps": 500,
    "sample_max_tokens": 80
  },
  "data": {
    "vocab_size": 8000,
    "stride_ratio": 0.5,
    "pad_token": "<|pad|>",
    "unk_token": "<|unk|>",
    "bos_token": "<|bos|>",
    "eos_token": "<|eos|>"
  },
  "name": "mini-gpt",
  "output_dir": "experiments",
  "seed": 42
}