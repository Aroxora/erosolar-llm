# Python
__pycache__/
*.pyc
*.pyo

# Trained model artifacts are regenerable by honest_pipeline.py — keep binaries out
# of git. The registry metadata (models/registry.json) is tracked; checkpoints are not.
models/*/
!models/registry.json

# Build artifacts (regenerable)
dist/
.angular/
erosolar-web-deploy/public/
node_modules/
*.log

# Cloud Run inference build context — assembled by inference_service/build.sh from
# the repo root (model checkpoint + module copies). Only app.py/Dockerfile/
# requirements.txt/build.sh are tracked.
inference_service/models/
inference_service/model.py
inference_service/infini_attention.py
inference_service/config.py
inference_service/tokenizer.py
inference_service/registry.py
inference_service/honest_pipeline.py

# Firebase deploy cache
erosolar-web-deploy/.firebase/
**/.firebase/

# OS / editor
.DS_Store
