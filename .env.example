# Template for local secrets. Copy to `.env` (which is gitignored) and fill in.
#   cp .env.example .env
# Real environment variables always take precedence over .env values.

# Image/Video generation provider.
IMAGE_VIDEO_GEN_API_KEY=
IMAGE_VIDEO_GEN_BASE_URL=

# Lambda Cloud API key (launches/terminates GPU instances).
LAMBDA_API_KEY=

# Web search (Tavily) — monthly quota; graceful "disabled until reset" handling.
TAVILY_API_KEY=
TAVILY_SEARCH_URL=

# DeepSeek API (OpenAI-compatible) — graceful "out of balance / top up" handling.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

# Fine-tuning telemetry (optional).
WANDB_API_KEY=

# Hugging Face access token for gated models / pushing checkpoints (optional).
HF_TOKEN=
HF_PUSH_REPO=

# ── Proton Bridge (local) + agentic outreach ──────────────────────────────
# Proton Mail Bridge exposes IMAP/SMTP on 127.0.0.1 (self-signed cert). The
# outreach worker (`python -m erosolar_agent.outreach run`) must run on the same
# host as Bridge. NEVER commit the real bridge password — it lives in .env only.
PROTON_BRIDGE_USER=
PROTON_BRIDGE_PASSWORD=
PROTON_IMAP_HOST=127.0.0.1
PROTON_IMAP_PORT=1143
PROTON_SMTP_HOST=127.0.0.1
PROTON_SMTP_PORT=1025
PROTON_SECURITY=starttls
OUTREACH_FROM_EMAIL=
OUTREACH_FROM_NAME=Erosolar
OUTREACH_ADMIN_EMAIL=
OUTREACH_LLM_MODEL=deepseek-v4-pro
OUTREACH_ALLOW_SEND=false
OUTREACH_MAX_PER_RUN=25
OUTREACH_MIN_SEND_INTERVAL_SEC=45
OUTREACH_POLL_SEC=30
FIREBASE_PROJECT_ID=erosolar-llm
FIREBASE_SERVICE_ACCOUNT=configs/firebase-service-account.json
OUTREACH_SUMMARY_MODEL=deepseek-v4-flash
OUTREACH_OWNER_EMAIL=bo@shang.software
